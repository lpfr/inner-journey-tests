+/* ---------------------------------------------------------------------- */
+/* Chapter 6 — "La chambre à deux" ambience layer (RoomSceneEffects.jsx)   */
+/* Sits above the background image and atmosphere, below all text/cards. */
+/* ---------------------------------------------------------------------- */
+
+.room-effects {
+  position: absolute;
+  inset: 0;
+  z-index: 3;
+  overflow: hidden;
+  pointer-events: none;
+  isolation: isolate;
+}
+
+.room-effects * {
+  pointer-events: none;
+}
+
+.room-effects__lamp-glow,
+.room-effects__shared-light,
+.room-effects__night-air,
+.room-effects__cool-wash {
+  position: absolute;
+  inset: 0;
+  display: block;
+}
+
+.room-effects__lamp-glow {
+  background: radial-gradient(circle at 50% 38%, var(--room-accent, rgba(255, 210, 148, 0.6)), transparent 46%);
+  filter: blur(2px);
+  mix-blend-mode: screen;
+  animation: roomLampBreathe 16s ease-in-out infinite;
+}
+
+.room-effects__lamp-glow--medium {
+  --lamp-low: 0.16;
+  --lamp-high: 0.3;
+  animation-duration: 16s;
+}
+
+.room-effects__lamp-glow--low {
+  --lamp-low: 0.1;
+  --lamp-high: 0.2;
+  animation-duration: 19s;
+}
+
+.room-effects__lamp-glow--stable {
+  --lamp-low: 0.18;
+  --lamp-high: 0.24;
+  animation-duration: 21s;
+}
+
+.room-effects__lamp-glow--soft {
+  --lamp-low: 0.12;
+  --lamp-high: 0.22;
+  animation-duration: 23s;
+}
+
+.room-effects__lamp-glow--balanced {
+  background:
+    radial-gradient(circle at 30% 42%, var(--room-accent, rgba(255, 210, 148, 0.6)), transparent 32%),
+    radial-gradient(circle at 70% 42%, var(--room-accent, rgba(255, 210, 148, 0.6)), transparent 32%);
+  --lamp-low: 0.14;
+  --lamp-high: 0.26;
+  animation-duration: 17s;
+}
+
+@keyframes roomLampBreathe {
+  0%,
+  100% {
+    opacity: var(--lamp-low, 0.14);
+  }
+  50% {
+    opacity: var(--lamp-high, 0.26);
+  }
+}
+
+.room-effects__shared-light {
+  background: radial-gradient(ellipse 62% 38% at 50% 46%, var(--room-accent, rgba(255, 210, 148, 0.6)), transparent 72%);
+  mix-blend-mode: screen;
+  animation: roomSharedBreathe 14s ease-in-out infinite;
+}
+
+@keyframes roomSharedBreathe {
+  0%,
+  100% {
+    opacity: 0.22;
+  }
+  50% {
+    opacity: 0.4;
+  }
+}
+
+.room-effects__curtain {
+  position: absolute;
+  top: -4%;
+  bottom: -4%;
+  width: 16%;
+  background: linear-gradient(180deg, rgba(8, 10, 18, 0) 0%, rgba(10, 12, 22, 0.26) 45%, rgba(8, 10, 18, 0) 100%);
+  filter: blur(6px);
+  opacity: 0.55;
+}
+
+.room-effects__curtain--left {
+  left: -3%;
+  animation: roomCurtainSwayLeft 22s ease-in-out infinite alternate;
+}
+
+.room-effects__curtain--right {
+  right: -3%;
+  animation: roomCurtainSwayRight 25s ease-in-out infinite alternate;
+  animation-delay: 2.4s;
+}
+
+.room-effects--airy .room-effects__curtain--left {
+  animation-duration: 17s;
+}
+
+.room-effects--airy .room-effects__curtain--right {
+  animation-duration: 19s;
+}
+
+@keyframes roomCurtainSwayLeft {
+  from {
+    transform: translateX(0) rotate(-0.5deg);
+  }
+  to {
+    transform: translateX(5px) rotate(0.6deg);
+  }
+}
+
+@keyframes roomCurtainSwayRight {
+  from {
+    transform: translateX(0) rotate(0.5deg);
+  }
+  to {
+    transform: translateX(-5px) rotate(-0.6deg);
+  }
+}
+
+.room-effects__night-air {
+  background: linear-gradient(115deg, rgba(120, 160, 210, 0.18) 0%, transparent 52%);
+  mix-blend-mode: screen;
+  animation: roomNightAirDrift 24s ease-in-out infinite alternate;
+}
+
+@keyframes roomNightAirDrift {
+  from {
+    opacity: 0.3;
+    transform: translateX(0);
+  }
+  to {
+    opacity: 0.5;
+    transform: translateX(-3%);
+  }
+}
+
+.room-effects__night-air--soft {
+  animation: roomNightAirDriftSoft 28s ease-in-out infinite alternate;
+}
+
+@keyframes roomNightAirDriftSoft {
+  from {
+    opacity: 0.16;
+    transform: translateX(0);
+  }
+  to {
+    opacity: 0.28;
+    transform: translateX(-1.5%);
+  }
+}
+
+.room-effects__cool-wash {
+  background: linear-gradient(200deg, rgba(110, 150, 205, 0.07), transparent 60%);
+  mix-blend-mode: screen;
+}
+
+.room-effects__steam-group {
+  position: absolute;
+  left: 50%;
+  bottom: 20%;
+  width: 36%;
+  height: 34%;
+  transform: translateX(-50%);
+  display: block;
+}
+
+.room-effects__steam {
+  position: absolute;
+  bottom: 0;
+  left: 40%;
+  width: 8px;
+  height: 54px;
+  background: linear-gradient(180deg, rgba(255, 250, 240, 0.24), transparent 78%);
+  filter: blur(3px);
+  border-radius: 50%;
+  opacity: 0;
+  animation: roomSteamRise 12s ease-in infinite;
+}
+
+.room-effects__steam--two {
+  left: 58%;
+  width: 7px;
+  height: 46px;
+  animation-delay: 4.5s;
+  animation-duration: 13s;
+}
+
+@keyframes roomSteamRise {
+  0% {
+    transform: translateY(0) scaleY(1);
+    opacity: 0;
+  }
+  18% {
+    opacity: 0.26;
+  }
+  65% {
+    opacity: 0.12;
+  }
+  100% {
+    transform: translateY(-64px) scaleY(1.5);
+    opacity: 0;
+  }
+}
+
+.room-effects__steam-group--fading .room-effects__steam {
+  animation-name: roomSteamRiseFading;
+  animation-duration: 18s;
+}
+
+@keyframes roomSteamRiseFading {
+  0% {
+    opacity: 0;
+    transform: translateY(0) scaleY(1);
+  }
+  15% {
+    opacity: 0.14;
+  }
+  70% {
+    opacity: 0.05;
+  }
+  100% {
+    opacity: 0;
+    transform: translateY(-50px) scaleY(1.3);
+  }
+}
+
+.room-effects__steam-group--subtle .room-effects__steam {
+  animation-name: roomSteamRiseSubtle;
+}
+
+@keyframes roomSteamRiseSubtle {
+  0% {
+    opacity: 0;
+  }
+  20% {
+    opacity: 0.1;
+  }
+  70% {
+    opacity: 0.04;
+  }
+  100% {
+    opacity: 0;
+    transform: translateY(-58px) scaleY(1.4);
+  }
+}
+
+.room-effects__thread-glow {
+  position: absolute;
+  left: 32%;
+  right: 32%;
+  top: 55%;
+  height: 2px;
+  background: linear-gradient(90deg, transparent, rgba(255, 214, 158, 0.6), transparent);
+  filter: blur(1px);
+  animation: roomThreadPulse 11s ease-in-out infinite;
+}
+
+@keyframes roomThreadPulse {
+  0%,
+  100% {
+    opacity: 0.28;
+  }
+  50% {
+    opacity: 0.6;
+  }
+}
+
+.room-effects__thread-glow--subtle {
+  animation-name: roomThreadPulseSubtle;
+  animation-duration: 14s;
+}
+
+@keyframes roomThreadPulseSubtle {
+  0%,
+  100% {
+    opacity: 0.12;
+  }
+  50% {
+    opacity: 0.3;
+  }
+}
+
+.room-effects__dust-layer {
+  position: absolute;
+  inset: 0;
+  display: block;
+}
+
+.room-effects__dust-mote {
+  position: absolute;
+  border-radius: 50%;
+  background: radial-gradient(circle, rgba(255, 232, 198, 0.55), transparent 72%);
+  opacity: 0.08;
+  animation: roomDustFloat 20s ease-in-out infinite;
+}
+
+@keyframes roomDustFloat {
+  0% {
+    transform: translate3d(0, 0, 0);
+    opacity: 0.08;
+  }
+  50% {
+    opacity: 0.24;
+  }
+  100% {
+    transform: translate3d(5px, -16px, 0);
+    opacity: 0.08;
+  }
+}
+
+@media (max-width: 720px) {
+  .room-effects__curtain {
+    width: 22%;
+    filter: blur(4px);
+  }
+
+  .room-effects__steam-group {
+    width: 44%;
+  }
+
+  .room-effects__dust-mote:nth-child(n + 4) {
+    display: none;
+  }
+}
+
+@media (prefers-reduced-motion: reduce) {
+  .room-effects__lamp-glow,
+  .room-effects__shared-light,
+  .room-effects__curtain,
+  .room-effects__night-air,
+  .room-effects__steam,
+  .room-effects__thread-glow,
+  .room-effects__dust-mote {
+    animation: none !important;
+  }
+
+  .room-effects__lamp-glow {
+    opacity: 0.18;
+  }
+
+  .room-effects__shared-light {
+    opacity: 0.3;
+  }
+
+  .room-effects__curtain {
+    opacity: 0.28;
+    transform: none;
+  }
+
+  .room-effects__night-air {
+    opacity: 0.2;
+  }
+
+  .room-effects__steam {
+    opacity: 0.08;
+  }
+
+  .room-effects__thread-glow {
+    opacity: 0.22;
+  }
+
+  .room-effects__dust-mote:nth-child(n + 3) {
+    display: none;
+  }
+}
